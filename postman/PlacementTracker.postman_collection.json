{
  "info": {
    "name": "Student Placement Tracker",
    "description": "API collection for the Student Placement Tracker backend. Run 'Login' first - it automatically saves the JWT into the {{token}} variable used by every other request.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080/api" },
    { "key": "token", "value": "" },
    { "key": "studentId", "value": "1" },
    { "key": "companyId", "value": "1" },
    { "key": "applicationId", "value": "1" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.data && json.data.token) {",
                  "    pm.collectionVariables.set('token', json.data.token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"Admin@123\"\n}" },
            "url": "{{baseUrl}}/auth/login"
          }
        },
        { "name": "Logout", "request": { "method": "POST", "url": "{{baseUrl}}/auth/logout" } }
      ]
    },
    {
      "name": "Students",
      "item": [
        {
          "name": "Create Student",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test Student\",\n  \"rollNumber\": \"JEC21CS999\",\n  \"email\": \"test.student@jecrc.edu\",\n  \"branch\": \"CSE\",\n  \"cgpa\": 8.5,\n  \"skills\": \"Java, React\",\n  \"phoneNumber\": \"9999999999\"\n}"
            },
            "url": "{{baseUrl}}/students"
          }
        },
        {
          "name": "Search Students",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/students?keyword=&branch=&minCgpa=&page=0&size=10"
          }
        },
        {
          "name": "Get Student By Id",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/students/{{studentId}}"
          }
        },
        {
          "name": "Get Distinct Branches",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/students/branches"
          }
        },
        {
          "name": "Update Student",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test Student Updated\",\n  \"rollNumber\": \"JEC21CS999\",\n  \"email\": \"test.student@jecrc.edu\",\n  \"branch\": \"CSE\",\n  \"cgpa\": 9.0,\n  \"skills\": \"Java, React, Spring Boot\",\n  \"phoneNumber\": \"9999999999\"\n}"
            },
            "url": "{{baseUrl}}/students/{{studentId}}"
          }
        },
        {
          "name": "Delete Student",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/students/{{studentId}}"
          }
        }
      ]
    },
    {
      "name": "Companies",
      "item": [
        {
          "name": "Create Company",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"companyName\": \"Test Corp\",\n  \"ctc\": 10.5,\n  \"location\": \"Jaipur\",\n  \"eligibilityCgpa\": 7.0,\n  \"lastDateToApply\": \"2026-09-01\"\n}"
            },
            "url": "{{baseUrl}}/companies"
          }
        },
        {
          "name": "Search Companies",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/companies?keyword=&page=0&size=10"
          }
        },
        {
          "name": "Update Company",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"companyName\": \"Test Corp\",\n  \"ctc\": 12.0,\n  \"location\": \"Jaipur\",\n  \"eligibilityCgpa\": 7.5,\n  \"lastDateToApply\": \"2026-09-15\"\n}"
            },
            "url": "{{baseUrl}}/companies/{{companyId}}"
          }
        },
        {
          "name": "Delete Company",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/companies/{{companyId}}"
          }
        }
      ]
    },
    {
      "name": "Applications",
      "item": [
        {
          "name": "Create Application",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"studentId\": {{studentId}},\n  \"companyId\": {{companyId}}\n}" },
            "url": "{{baseUrl}}/applications"
          }
        },
        {
          "name": "Search Applications",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/applications?status=&studentId=&companyId=&page=0&size=10"
          }
        },
        {
          "name": "Update Application Status",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"status\": \"SHORTLISTED\"\n}" },
            "url": "{{baseUrl}}/applications/{{applicationId}}/status"
          }
        },
        {
          "name": "Delete Application",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/applications/{{applicationId}}"
          }
        }
      ]
    },
    {
      "name": "Dashboard & Reports",
      "item": [
        {
          "name": "Dashboard Stats",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/dashboard/stats"
          }
        },
        {
          "name": "Branch-wise Report",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/reports/branch-wise"
          }
        },
        {
          "name": "Company-wise Report",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/reports/company-wise"
          }
        }
      ]
    }
  ]
}
